# NewsAgent 环境变量配置
# 复制此文件为 .env 并填入真实值：cp .env.example .env

# ── Gmail SMTP ────────────────────────────────────────────────
# 你的 Gmail 地址（用于发送邮件）
GMAIL_USER=your_gmail@gmail.com

# Gmail 应用专用密码（16位，不含空格）
# 获取方式：myaccount.google.com → 安全 → 两步验证 → 应用专用密码
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── GitHub Pages ──────────────────────────────────────────────
# Personal Access Token，需要 repo 权限
# 获取方式：github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
